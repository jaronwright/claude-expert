# ============================================================================
# Claude Expert — environment variables
# Copy this file to `.env` and fill in the values below.
# ============================================================================

# ---- Anthropic API -----------------------------------------------------------
# Optional fallback API key used when a signed-in user has not saved their own.
# Create a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- NextAuth ---------------------------------------------------------------
# Base URL of the deployed app. Use http://localhost:3000 for local dev.
NEXTAUTH_URL=http://localhost:3000

# Secret used to sign session JWTs. Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# ---- GitHub OAuth -----------------------------------------------------------
# Create a GitHub OAuth app at https://github.com/settings/developers
# Authorization callback URL: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- Database ---------------------------------------------------------------
# SQLite for local dev. On Vercel, swap for a Postgres URL and update the
# datasource provider in prisma/schema.prisma accordingly.
DATABASE_URL="file:./dev.db"

# ---- Encryption -------------------------------------------------------------
# 32-byte key (base64) used to AES-256-GCM-encrypt per-user API keys at rest.
# Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=
